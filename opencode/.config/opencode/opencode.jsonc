{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "~/.local/share/opencode/packages/superpowers"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "pnpx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "open-design": {
      "type": "local",
      "command": [
        "{env:HOME}/.opendesign/node_modules/.bin/od",
        "mcp"
      ],
      "environment": {
        "OD_DATA_DIR": "{env:HOME}/.opendesign/.od",
        "OD_SIDECAR_IPC_PATH": "/tmp/open-design/ipc/default/daemon.sock"
      }
    }
  }
}
