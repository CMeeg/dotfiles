{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "~/.local/share/opencode/packages/superpowers"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "pnpx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp"
    }
  }
}
